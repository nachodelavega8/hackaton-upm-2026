# ─── WeatherSelf — Production / ngrok config ──────────────────────────────────
# Fill in your actual ngrok URLs (no trailing slash) before running `npm run build`
# or before starting `npm run dev` if you want Vite dev-mode to hit the backend ngrok.
#
# How to get the URLs:
#   ngrok http 8000   →  copy the https URL  →  VITE_API_BASE_URL
#   ngrok http 5173   →  copy the https URL  →  (frontend URL, used for CORS reference only)

VITE_API_BASE_URL=https://REPLACE_WITH_BACKEND_NGROK_URL.ngrok-free.app
VITE_WS_URL=wss://REPLACE_WITH_BACKEND_NGROK_URL.ngrok-free.app/ws
